# Copy to .env for local development (never commit the real .env).

# Core
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=http://localhost:8081,http://localhost:19006

# Database — leave unset to use local SQLite. On Render this is injected.
# DATABASE_URL=postgres://USER:PASS@HOST:5432/DBNAME

# Session lifetime for issued access tokens, in hours.
TOKEN_TTL_HOURS=24

# Per-IP rate limiting on auth endpoints. On by default; for accurate limits
# across gunicorn workers, back the Django cache with Redis (or rate-limit at
# the edge). Set to false to disable.
RATELIMIT_ENABLE=true

# --- Production security (all auto-ON when DJANGO_DEBUG=false) ---
# Behind Render's TLS proxy, a real deploy automatically enforces the HTTPS
# redirect, secure session/CSRF cookies, and 1-year HSTS — no setup needed.
# Override a single flag only for an unusual setup (e.g. a non-TLS network):
# DJANGO_SSL_REDIRECT=true
# DJANGO_SESSION_COOKIE_SECURE=true
# DJANGO_CSRF_COOKIE_SECURE=true
# DJANGO_HSTS_SECONDS=31536000
# DJANGO_HSTS_INCLUDE_SUBDOMAINS=true
# DJANGO_HSTS_PRELOAD=false   # opt-in: only once the domain is committed HTTPS-only

# --- Third-party services (leave blank in dev: the app runs in MOCK mode) ---
# VTU / bills — VTU.ng (v2): airtime, data, cable, electricity, betting. JWT
# Bearer auth, no IP whitelisting. Set a long-lived token (VTUNG_API_KEY) OR
# username+password (a JWT is fetched & refreshed automatically). Blank => MOCK.
VTUNG_BASE_URL=https://vtu.ng
VTUNG_API_KEY=
VTUNG_USERNAME=
VTUNG_PASSWORD=

# Money-movement rail — Kora (Korapay): funding (checkout + virtual accounts),
# payouts, balances, identity (BVN/NIN/vNIN) and card issuing. Kora is the sole
# rail. One base URL serves both modes; the key prefix (sk_test_/sk_live_)
# selects test vs live. Blank SECRET_KEY => mock mode. Diagnose with
# `manage.py kora_check`. Set the Kora dashboard webhooks to:
#   pay-in:  https://<host>/api/fund/webhook/
#   payout:  https://<host>/api/transfers/webhook/
KORA_BASE_URL=https://api.korapay.com/merchant
KORA_SECRET_KEY=
# Public key — only needed for public-key endpoints (e.g. list banks); safe to expose.
KORA_PUBLIC_KEY=
# Set to any secret to enable the browser self-test at /kora-diagnose?token=...
# (a no-shell way to diagnose Kora connectivity). Leave blank to disable it.
KORA_DIAG_TOKEN=
# Virtual-card backend: "kora" or "issuer" (the generic CARD_ISSUER). Blank =>
# auto (issuer if configured, else Kora).
CARD_PROVIDER=

# Open banking — Mono (link external bank, view balance/transactions, fund the
# wallet via DirectPay). The Connect widget runs in the app with PUBLIC_KEY;
# server calls use SECRET_KEY (mono-sec-key header). Blank SECRET_KEY => mock
# mode. WEBHOOK_SECRET is compared to the mono-webhook-secret header. Set the
# Mono dashboard webhook to https://<host>/api/banklink/webhook/.
MONO_BASE_URL=https://api.withmono.com
MONO_SECRET_KEY=
MONO_PUBLIC_KEY=
MONO_WEBHOOK_SECRET=

# SMS / OTP — Sendchamp
SENDCHAMP_BASE_URL=https://api.sendchamp.com/api/v1
SENDCHAMP_API_KEY=
SENDCHAMP_SENDER_NAME=Sendchamp

# Email / OTP fallback — Resend. Sends the same OTP code in parallel with
# Sendchamp; blank API_KEY => mock mode (silent success). FROM_EMAIL must be on
# a verified Resend sending domain or Resend will reject.
RESEND_BASE_URL=https://api.resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@zitch.ng

# KYC — BVN / NIN / vNIN verification is done by Kora Identity (KORA_SECRET_KEY
# above). Prembly below is used ONLY for the selfie/liveness step, which Kora
# does not provide.
# KYC — liveness/face — Prembly (IdentityPass)
PREMBLY_BASE_URL=https://api.prembly.com
PREMBLY_API_KEY=
PREMBLY_APP_ID=

# Card issuer — virtual cards (provider TBD)
CARD_ISSUER_BASE_URL=
CARD_ISSUER_API_KEY=
CARD_ISSUER_BRAND=Verve

# --- WhatsApp channel — Meta Cloud API (blank TOKEN => MOCK mode) ---
# Webhook: GET/POST https://<host>/webhooks/whatsapp  (set the same VERIFY_TOKEN
# in the Meta app dashboard). APP_SECRET enables inbound HMAC verification.
WHATSAPP_BASE_URL=https://graph.facebook.com/v21.0
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_BUSINESS_NUMBER=        # digits only (e.g. 234801...), for wa.me deep links

# WhatsApp AI intent layer (blank API_KEY => AI off; the deterministic router
# handles everything). The model only proposes intents; it never moves money.
LLM_API_KEY=
LLM_MODEL=                       # optional, e.g. claude-haiku-4-5-20251001

# FX rail — Fincra (multi-currency conversion). Blank SECRET_KEY => MOCK mode
# (deterministic rates, auto-settle). NGN/USD/GBP/CAD settle; CNY is quote-only.
FINCRA_BASE_URL=https://api.fincra.com
FINCRA_SECRET_KEY=
FINCRA_BUSINESS_ID=
