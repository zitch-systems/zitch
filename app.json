{
  "expo": {
    "name": "Zitch",
    "slug": "zitch",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo1.png",
    "scheme": "Zitch",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/logo1.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zitch.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo1.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "INTERNET",
        "CAMERA",
        "ACCESS_FINE_LOCATION"
      ],
      "package": "com.zitch.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo1.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Zitch to use Face ID to sign you in and approve payments."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow Zitch to use the camera to verify your identity (face check)."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Zitch to use the camera to scan QR codes for payments.",
          "recordAudioAndroid": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
