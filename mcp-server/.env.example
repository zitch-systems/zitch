# Copy to .env (or set in your MCP client config). Never commit a real token.

# Zitch API base URL. Production default is https://api.zitch.ng; point at a dev
# host while testing, e.g. http://localhost:8000
ZITCH_API_URL=https://api.zitch.ng

# A normal Zitch user access token (the same token the mobile app uses). The MCP
# server acts AS this user. Treat it like a password.
ZITCH_ACCESS_TOKEN=

# Set to 1/true to expose ONLY read tools (balance, history, resolve, list) and
# disable all money movement. Equivalent to running with --read-only.
ZITCH_MCP_READONLY=
