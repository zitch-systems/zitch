# Zitch Expo app — public runtime config (inlined into the JS bundle at build time).
# Copy to `.env` for local development. Anything prefixed EXPO_PUBLIC_ is readable
# in the client, so NEVER put secrets here.

# Base URL of the Zitch backend API.
#   web / iOS simulator:        http://localhost:8000
#   Android emulator:           http://10.0.2.2:8000
#   physical device on Wi-Fi:   http://<your-LAN-IP>:8000
# Leave unset to use the production Render API (see components/configFiles/apiConfig.tsx).
EXPO_PUBLIC_API_URL=http://localhost:8000
